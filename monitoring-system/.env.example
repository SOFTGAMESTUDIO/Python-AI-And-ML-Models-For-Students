# ============================================================
# Monitoring System — Environment Variables
# Copyright (c) 2026 Soft Game Studio
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ----- Application -----
ENVIRONMENT=development
DEBUG=true

# ----- Website Monitoring -----
WEBSITE_URL=https://website.com
CHECK_INTERVAL=30
REQUEST_TIMEOUT=10

# ----- Network Monitoring -----
ENABLE_PACKET_MONITORING=true
NETWORK_INTERFACE=Wi-Fi

# ----- Telegram Alerts -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Discord Alerts -----
DISCORD_WEBHOOK_URL=

# ----- Email Alerts -----
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
ALERT_EMAIL=

# ----- Firebase -----
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# ----- Dashboard / API -----
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ----- Database -----
DATABASE_URL=sqlite:///database/monitor.db

# ----- Security -----
MAX_REQUESTS_PER_MINUTE=100
ENABLE_RATE_LIMITING=true

# ----- DDoS Detection -----
ENABLE_DDOS_DETECTION=true
DDOS_PACKET_THRESHOLD=1000

# ----- Performance -----
MAX_WORKERS=10
MAX_RETRIES=3
RETRY_DELAY=2
